# ============================================================
# ENVIRONNEMENT SERVEUR - PostgreSQL, Redis, Gitea, Dokploy déjà installés
# ============================================================

# ── POSTGRESQL (utiliser celui qui tourne déjà: deviprop-postgres) ─────
# Récupérer les credentials de votre PostgreSQL existant
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_PASSWORD=  # Password du PostgreSQL existant sur le serveur

# NOTE: Le service paperclip va créer sa propre database "paperclip_db"
# dans le PostgreSQL existant. Assurez-vous que le user a les droits CREATE DATABASE

# ── GITEA (utiliser celui qui tourne déjà sur port 3001) ───────────────
# Créer un token dans Gitea UI > Settings > Applications > Generate New Token
GITEA_API_TOKEN=

# ── PAPERCLIP ───────────────────────────────────────────────────────────
PAPERCLIP_ADMIN_EMAIL=admin@deviprop.com
PAPERCLIP_ADMIN_PASSWORD=  # Choisir un mot de passe fort
PAPERCLIP_AUTH_SECRET=  # openssl rand -hex 32
PAPERCLIP_AGENT_JWT_SECRET=  # openssl rand -hex 32
PAPERCLIP_PUBLIC_URL=http://192.168.94.96:3100  # URL publique du serveur
PAPERCLIP_ALLOWED_HOSTNAMES=192.168.94.96,localhost

# ── DOKPLOY (utiliser celui qui tourne déjà) ────────────────────────────
# Générer un token dans Dokploy UI > Settings > API Tokens
DOKPLOY_API_URL=http://host.docker.internal:3000
DOKPLOY_API_TOKEN=  # À générer dans Dokploy
DOKPLOY_WEBHOOK_URL=http://192.168.94.96:3000  # URL publique
DOKPLOY_DOMAIN=deviprop.com  # Votre domaine

# ── ANTHROPIC (pour les agents Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...  # Votre clé API
